---
import type { LandingSection } from "../content/landing";

interface Props {
  sections: LandingSection[];
}

const { sections } = Astro.props;
---

<section class="section-pad presentations" aria-labelledby="presentations-title">
  <div class="container">
    <div class="section-heading section-heading--wide">
      <p class="eyebrow">Подборка помещений</p>
      <h2 id="presentations-title">Сравните параметры коммерческих помещений</h2>
      <p>
        В карточках собраны данные, которые удалось подтвердить по презентациям: адрес, метро, планировочные параметры и видимые особенности фасада или входной группы.
      </p>
    </div>

    <div class="presentation-list">
      {sections.map((section, index) => (
        <article class:list={["presentation-card", index % 2 === 1 && "presentation-card--reverse"]} id={section.id}>
          {section.image && (
            <figure class:list={["presentation-card__media", "premium-frame", section.image.role === "plan" ? "premium-frame--contain" : "premium-frame--photo"]}>
              <img
                src={section.image.src}
                alt={section.image.alt}
                width="920"
                height="620"
                loading="lazy"
              />
            </figure>
          )}

          <div class="presentation-card__body">
            <p class="eyebrow">{section.eyebrow}</p>
            <h3>{section.title}</h3>
            <p class="presentation-card__summary">{section.summary}</p>

            <dl class="spec-grid" aria-label={`Параметры объекта: ${section.title}`}>
              {section.specs.map((spec) => (
                <div class="spec-chip">
                  <dt>{spec.label}</dt>
                  <dd>{spec.value}</dd>
                </div>
              ))}
            </dl>

            {section.highlights.length > 0 && (
              <ul class="highlight-list" aria-label={`Особенности объекта: ${section.title}`}>
                {section.highlights.map((highlight) => <li>{highlight}</li>)}
              </ul>
            )}

            <div class="presentation-card__actions">
              <a class="button button--primary" href="#lead-form">{section.ctaLabel}</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
