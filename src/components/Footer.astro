---
import type { landingContent } from "../content/landing";

type CtaContent = typeof landingContent.cta;

interface Props {
  cta: CtaContent;
}

const { cta } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer__grid">
    <div>
      <a class="footer-brand" href="#hero-title" aria-label="FIRST LINE, перейти в начало страницы">FIRST LINE</a>
      <p>Подборка коммерческих помещений для аренды в Санкт-Петербурге.</p>
    </div>

    <address class="footer-contacts">
      <strong>Контакты</strong>
      <span>Телефон и email будут добавлены после подтверждения контактных данных.</span>
      <span>Санкт-Петербург</span>
    </address>

    <div class="footer-links">
      <strong>Материалы</strong>
      <a href={cta.presentationUrl}>{cta.actionLabel}</a>
    </div>
  </div>
  <div class="container site-footer__bottom">
    <span>© {year} FIRST LINE</span>
    <span>Коммерческая недвижимость</span>
  </div>
</footer>
