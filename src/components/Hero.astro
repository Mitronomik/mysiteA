---
import type { landingContent } from "../content/landing";

type HeroContent = typeof landingContent.hero;
type CtaContent = typeof landingContent.cta;

interface Props {
  hero: HeroContent;
  cta: CtaContent;
}

const { hero, cta } = Astro.props;
---

<section class="hero section-pad" aria-labelledby="hero-title">
  <div class="container hero__grid">
    <div class="hero__content">
      <p class="eyebrow">{hero.eyebrow}</p>
      <h1 id="hero-title">{hero.title}</h1>
      <p class="hero__lead">{hero.lead}</p>
      <div class="hero__actions" aria-label="Основные действия">
        <a class="button button--primary" href="#lead-form">Оставить заявку</a>
        <a class="button button--ghost" href={hero.presentationUrl}>{cta.actionLabel}</a>
      </div>
      <dl class="hero__stats" aria-label="Ключевые параметры подборки">
        <div>
          <dt>5</dt>
          <dd>презентаций</dd>
        </div>
        <div>
          <dt>4</dt>
          <dd>района города</dd>
        </div>
        <div>
          <dt>PDF</dt>
          <dd>единый файл</dd>
        </div>
      </dl>
    </div>

    <figure class="hero__media premium-frame">
      <img
        src={hero.primaryImage.src}
        alt={hero.primaryImage.alt}
        width="1040"
        height="720"
        fetchpriority="high"
      />
      <figcaption>
        <span>Источник</span>
        {hero.primaryImage.sourcePdf}
      </figcaption>
    </figure>
  </div>
</section>
