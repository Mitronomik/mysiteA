---
import type { landingContent } from "../content/landing";

type Benefit = typeof landingContent.benefits[number];

interface Props {
  benefits: Benefit[];
}

const { benefits } = Astro.props;
---

<section class="section-pad benefits" aria-labelledby="benefits-title">
  <div class="container">
    <div class="section-heading section-heading--compact">
      <p class="eyebrow">Почему подборка уже готова к показу</p>
      <h2 id="benefits-title">Премиальный визуальный каркас без неподтверждённых обещаний</h2>
    </div>

    <div class="benefits__grid">
      {benefits.map((benefit, index) => (
        <article class="benefit-card">
          <span class="benefit-card__number">0{index + 1}</span>
          <h3>{benefit.title}</h3>
          <p>{benefit.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>
