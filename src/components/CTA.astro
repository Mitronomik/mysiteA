---
import type { landingContent } from "../content/landing";

type CtaContent = typeof landingContent.cta;

interface Props {
  cta: CtaContent;
}

const { cta } = Astro.props;
---

<section class="section-pad cta-section" aria-labelledby="cta-title">
  <div class="container">
    <div class="cta-panel">
      <div>
        <p class="eyebrow">Обсудить подборку</p>
        <h2 id="cta-title">{cta.title}</h2>
        <p>{cta.text}</p>
        {cta.conditions && (
          <ul class="condition-list" aria-label="Коммерческие условия">
            {cta.conditions.map((condition) => <li>{condition}</li>)}
          </ul>
        )}
      </div>
      <div class="cta-panel__actions">
        <a class="button button--light" href="#lead-form">Перейти к форме</a>
        <a class="button button--outline-light" href={cta.presentationUrl}>{cta.actionLabel}</a>
      </div>
    </div>
  </div>
</section>
