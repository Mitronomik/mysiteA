---
import "../styles/global.css";
import { landingContent } from "../content/landing";

const { hero, benefits, sections, cta } = landingContent;
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>FIRST LINE · контентный scaffold лендинга</title>
  </head>
  <body>
    <main class="page-shell">
      <section class="scaffold-hero" aria-labelledby="page-title">
        <div>
          <p class="eyebrow">{hero.eyebrow}</p>
          <h1 id="page-title">{hero.title}</h1>
          <p class="lead">{hero.lead}</p>
          <a class="cta-link" href={hero.presentationUrl}>{cta.actionLabel}</a>
        </div>
        <figure class="hero-image">
          <img src={hero.primaryImage.src} alt={hero.primaryImage.alt} width="900" height="560" />
        </figure>
      </section>

      <section class="scaffold-section" aria-labelledby="benefits-title">
        <p class="eyebrow">PR 1 content scaffold</p>
        <h2 id="benefits-title">Подготовленные смысловые опоры</h2>
        <div class="scaffold-grid">
          {benefits.map((benefit) => (
            <article class="scaffold-card">
              <h3>{benefit.title}</h3>
              <p>{benefit.text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="scaffold-section" aria-labelledby="objects-title">
        <p class="eyebrow">Source PDFs</p>
        <h2 id="objects-title">Объекты из презентаций</h2>
        <div class="object-list">
          {sections.map((section) => (
            <article class="object-card">
              {section.image && (
                <img src={section.image.src} alt={section.image.alt} width="720" height="450" loading="lazy" />
              )}
              <div class="object-card__body">
                <p class="eyebrow">{section.eyebrow}</p>
                <h3>{section.title}</h3>
                <p>{section.summary}</p>
                <ul>
                  {section.facts.map((fact) => <li>{fact}</li>)}
                </ul>
              </div>
            </article>
          ))}
        </div>
      </section>

      <aside class="scaffold-note" aria-labelledby="scope-title">
        <p class="eyebrow">Scope boundary</p>
        <h2 id="scope-title">Не финальный UI</h2>
        <p>{cta.text}</p>
      </aside>
    </main>
  </body>
</html>
