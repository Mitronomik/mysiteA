---
import "../styles/global.css";
import { landingContent } from "../content/landing";
import Hero from "../components/Hero.astro";
import Benefits from "../components/Benefits.astro";
import PresentationSections from "../components/PresentationSections.astro";
import Gallery from "../components/Gallery.astro";
import CTA from "../components/CTA.astro";
import LeadForm from "../components/LeadForm.astro";
import Footer from "../components/Footer.astro";
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>FIRST LINE · коммерческие помещения в Санкт-Петербурге</title>
  </head>
  <body>
    <main>
      <Hero hero={landingContent.hero} cta={landingContent.cta} />
      <Benefits benefits={landingContent.benefits} />
      <PresentationSections sections={landingContent.sections} />
      <Gallery images={landingContent.gallery} />
      <CTA cta={landingContent.cta} />
      <LeadForm />
    </main>
    <Footer cta={landingContent.cta} />
  </body>
</html>
